# Gemini API配置
GEMINI_API_KEY=your_gemini_api_key_here

# 服务器端口
PORT=3002

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_database_password
DB_NAME=electric_ai_tool

# CDN配置（如果使用云存储服务）
CDN_ENDPOINT=https://your-cdn-endpoint.com
CDN_BUCKET=your-bucket-name
CDN_ACCESS_KEY=your_cdn_access_key
CDN_SECRET_KEY=your_cdn_secret_key

# 如果CDN配置为空，图片将保存到本地 /tmp/cdn_uploads/ 目录

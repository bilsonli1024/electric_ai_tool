# AI模型API配置
# Gemini API（默认）
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI GPT API（可选）
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_API_BASE=https://api.openai.com/v1

# DeepSeek API（可选）
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_API_BASE=https://api.deepseek.com/v1

# 服务器端口
PORT=3002

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_database_password
DB_NAME=electric_ai_tool

# 图片存储配置
# 存储方式: local=本地存储, cdn=CDN存储
IMAGE_STORAGE_TYPE=local

# CDN配置（当IMAGE_STORAGE_TYPE=cdn时使用）
CDN_ENDPOINT=https://your-cdn-endpoint.com
CDN_BUCKET=your-bucket-name
CDN_ACCESS_KEY=your_cdn_access_key
CDN_SECRET_KEY=your_cdn_secret_key

# 本地存储配置（当IMAGE_STORAGE_TYPE=local时使用，默认）
# 本地存储目录将自动创建在: ./uploads/


# GEMINI_API_KEY: Required for Gemini AI API calls (used by backend only).
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# 前端开发服务端口（默认 3000）
VITE_PORT=3000

# 后端 API 服务端口（默认 3001）
PORT=3001

# 前端调用后端的基础 URL
# 开发环境: http://localhost:3001
# 生产环境: 改为实际后端部署地址
VITE_API_BASE_URL=http://localhost:3001
